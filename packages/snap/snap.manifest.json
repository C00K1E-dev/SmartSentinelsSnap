{
  "version": "0.1.1",
  "description": "The official SmartSentinels interface for MetaMask.",
  "proposedName": "SmartSentinels Alerts",
  "repository": {
    "type": "git",
    "url": "https://github.com/C00K1E-dev/SmartSentinelsSnap"
  },
  "source": {
    "shasum": "AH4tfCMwR4yY5lfltena3XBZqeH+S8E3FTAFnOZk4NY=",
    "location": {
      "npm": {
        "filePath": "dist/bundle.js",
        "iconPath": "images/logo.svg",
        "packageName": "smartsentinels-alerts",
        "registry": "https://registry.npmjs.org/"
      }
    }
  },
  "initialPermissions": {
    "snap_dialog": {},
    "snap_notify": {},
    "snap_manageState": {},
    "endowment:rpc": {
      "dapps": true,
      "snaps": false
    },
    "endowment:network-access": {},
    "endowment:ethereum-provider": {},
    "endowment:page-home": {},
    "endowment:cronjob": {
      "jobs": [
        {
          "expression": "*/30 * * * *",
          "request": {
            "method": "checkCampaigns"
          }
        }
      ]
    }
  },
  "manifestVersion": "0.1"
}
